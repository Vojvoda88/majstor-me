// Majstor.me - Marketplace for Handymen - Montenegro
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  USER
  HANDYMAN
  ADMIN
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum UrgencyLevel {
  HITNO_DANAS
  U_NAREDNA_2_DANA
  NIJE_HITNO
}

enum PriceType {
  PO_DOGOVORU
  OKVIRNA
  IZLAZAK_NA_TEREN
  FIKSNA
}

enum VerifiedStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ============ MODELS ============

model User {
  id            String   @id @default(cuid())
  role          UserRole @default(USER)
  name          String
  email         String   @unique
  phone         String?
  passwordHash  String   @map("password_hash")
  city          String?
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  handymanProfile HandymanProfile?
  requests        Request[]       @relation("RequestCreator")
  handymanInvites HandymanInvite[]
  offers          Offer[]
  reviewsGiven    Review[]        @relation("Reviewer")
  reviewsReceived Review[]        @relation("Reviewee")
  reportsMade     Report[]        @relation("ReportReporter")
  reportsAgainst  Report[]        @relation("ReportReported")
  adminActions    AdminAction[]
  messagesSent    Message[]
  notifications   Notification[]
  creditTransactions CreditTransaction[]
  contactUnlocks     RequestContactUnlock[]
  pushSubscriptions  PushSubscription[]

  @@map("users")
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  EMERGENCY_ONLY
}

model Category {
  id               String           @id @default(cuid())
  name             String           @unique
  workerCategories WorkerCategory[]

  @@map("categories")
}

model WorkerCategory {
  id         String   @id @default(cuid())
  workerId   String   @map("worker_id")
  categoryId String   @map("category_id")

  worker   HandymanProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  category Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([workerId, categoryId])
  @@index([workerId])
  @@index([categoryId])
  @@map("worker_categories")
}

model HandymanProfile {
  id                    String             @id @default(cuid())
  userId                String             @unique @map("user_id")
  bio                   String?
  avatarUrl             String?            @map("avatar_url")
  galleryImages         String[]           @default([]) @map("gallery_images")
  cities                String[]           // Cities where handyman works
  workerCategories      WorkerCategory[]
  yearsOfExperience     Int?               @map("years_of_experience")
  startingPrice         Float?             @map("starting_price")
  completedJobsCount    Int                @default(0) @map("completed_jobs_count")
  averageResponseMinutes Int?              @map("average_response_minutes")
  serviceAreasDescription String?          @map("service_areas_description")
  travelRadiusKm        Int?               @map("travel_radius_km")
  availabilityStatus    AvailabilityStatus? @default(AVAILABLE) @map("availability_status")
  verifiedStatus        VerifiedStatus     @default(PENDING) @map("verified_status")
  ratingAvg             Float              @default(0) @map("rating_avg")
  reviewCount           Int                @default(0) @map("review_count")
  subscriptionPlan      String             @default("FREE") @map("subscription_plan")
  isPromoted            Boolean            @default(false) @map("is_promoted")
  promotedUntil         DateTime?          @map("promoted_until")
  creditsBalance        Int                @default(0) @map("credits_balance")
  viberPhone            String?            @map("viber_phone")
  whatsappPhone         String?            @map("whatsapp_phone")
  createdAt             DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("handyman_profiles")
}

model CreditTransaction {
  id           String   @id @default(cuid())
  handymanId   String   @map("handyman_id") // User.id of handyman
  amount       Int      // positive = add, negative = spend
  type         String   // OFFER_SENT, CONTACT_UNLOCK, PURCHASE, BONUS, REFUND
  referenceId  String?  @map("reference_id") // e.g. offerId for OFFER_SENT
  balanceAfter Int      @map("balance_after")
  createdAt    DateTime @default(now()) @map("created_at")

  handyman User @relation(fields: [handymanId], references: [id], onDelete: Cascade)

  @@index([handymanId])
  @@map("credit_transactions")
}

model Request {
  id              String        @id @default(cuid())
  userId          String?       @map("user_id") // null = guest zahtjev
  category        String
  subcategory     String?
  title           String?       @map("title") // naslov problema
  description     String
  city            String
  address         String?
  urgency         UrgencyLevel  @default(NIJE_HITNO)
  status          RequestStatus @default(OPEN)
  photos          String[]      @default([]) // URLs from storage
  requesterName   String?       @map("requester_name") // za guest
  requesterPhone  String?       @map("requester_phone") // skriven dok ne otključa
  requesterEmail  String?       @map("requester_email") // opciono
  requesterToken  String?       @unique @map("requester_token") // za guest da vidi/prihvati
  createdAt       DateTime      @default(now()) @map("created_at")

  user              User?                @relation("RequestCreator", fields: [userId], references: [id], onDelete: Cascade)
  offers            Offer[]
  review            Review?
  report            Report[]
  conversation      Conversation?
  handymanInvites   HandymanInvite[]
  contactUnlocks    RequestContactUnlock[]

  @@index([status])
  @@index([city])
  @@index([category])
  @@index([createdAt])
  @@map("requests")
}

model RequestContactUnlock {
  id         String   @id @default(cuid())
  requestId  String   @map("request_id")
  handymanId String   @map("handyman_id")

  request  Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  handyman User    @relation(fields: [handymanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([requestId, handymanId])
  @@index([requestId])
  @@index([handymanId])
  @@map("request_contact_unlocks")
}

model Offer {
  id           String      @id @default(cuid())
  requestId    String      @map("request_id")
  handymanId   String      @map("handyman_id") // References User (handyman)
  priceType    PriceType   @map("price_type")
  priceValue   Float?      @map("price_value") // Optional for PO_DOGOVORU
  message      String?
  proposedDate DateTime?   @map("proposed_date")
  proposedArrival String?  @map("proposed_arrival") // procijenjeni dolazak (npr. "Sutra ujutro")
  status       OfferStatus @default(PENDING)
  createdAt    DateTime    @default(now()) @map("created_at")

  request  Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  handyman User    @relation(fields: [handymanId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([handymanId])
  @@index([status])
  @@map("offers")
}

model Review {
  id         String   @id @default(cuid())
  requestId  String   @unique @map("request_id")
  reviewerId String   @map("reviewer_id")   // User who leaves review (request creator)
  revieweeId String   @map("reviewee_id")   // Handyman being reviewed
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  request  Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewer User    @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User    @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Report {
  id             String       @id @default(cuid())
  reporterId     String       @map("reporter_id")
  reportedUserId String       @map("reported_user_id")
  requestId      String?      @map("request_id")
  type           String
  description    String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now()) @map("created_at")

  reporter     User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User     @relation("ReportReported", fields: [reportedUserId], references: [id], onDelete: Cascade)
  request      Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@map("reports")
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String   @map("admin_id")
  targetType String   @map("target_type") // "user" | "handyman" | "request" | "report"
  targetId   String   @map("target_id")
  action     String
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_actions")
}

model Conversation {
  id        String    @id @default(cuid())
  requestId String    @unique @map("request_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  request  Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   // NEW_OFFER, OFFER_ACCEPTED, NEW_MESSAGE, NEW_REVIEW, VERIFIED
  title     String
  body      String?  @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model HandymanInvite {
  id        String   @id @default(cuid())
  inviterId String   @map("inviter_id")
  email     String?
  phone     String?
  requestId String?  @map("request_id")
  token     String   @unique
  status    String   @default("PENDING") // PENDING, SENT, ACCEPTED
  createdAt DateTime @default(now()) @map("created_at")

  inviter User     @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([inviterId])
  @@map("handyman_invites")
}
