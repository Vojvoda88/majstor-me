# Database - Supabase PostgreSQL
# Transaction mode (port 6543) - za app runtime. Obavezno ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (port 5432) - za prisma db push / migrate
DIRECT_DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Site URL (za canonical, sitemap - fallback: NEXTAUTH_URL)
NEXT_PUBLIC_SITE_URL="https://brzimajstor.me"

# Admin email (za seed - npm run db:seed)
ADMIN_EMAIL=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Resend (Email)
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="BrziMajstor.ME <noreply@brzimajstor.me>"

# PWA Push Notifications (web-push VAPID keys)
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
