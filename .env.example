# Database - Supabase PostgreSQL
# Transaction mode (port 6543) - za app runtime. Obavezno ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (port 5432) - za prisma db push / migrate
DIRECT_DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Site URL (canonical, sitemap, OG). Produkcija MORA biti https://www.brzimajstor.me — nikad *.vercel.app
NEXT_PUBLIC_SITE_URL="https://www.brzimajstor.me"

# Javni listing majstora (početna, kategorije, /api/handymen): dodatno isključi ručne test naloge
# (osim ugrađenih @test.me, @local.majstor.demo, imena Smoke/Backlog — vidi lib/demo-email.ts).
# UUID iz admin panela ili baze, odvojeni zarezom:
# HANDYMAN_PUBLIC_EXCLUDE_USER_IDS="aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
# Ili tačan email test naloga (više odvojeno zarezom):
# HANDYMAN_PUBLIC_EXCLUDE_EMAILS="test@gmail.com,drugi@domen.me"

# Admin email (za seed - npm run db:seed)
ADMIN_EMAIL=""

# NextAuth — u produkciji isti origin kao u browseru: https://www.brzimajstor.me (ne Vercel deployment URL)
# Lokalno npr. http://localhost:3010
NEXTAUTH_URL="http://localhost:3010"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Privremeno (Vercel): LOGIN_AUTH_DEBUG=1 ili LOG_AUTH_STEPS=1 — detaljni log u authorize (user not found / hash / mismatch); ne loguje lozinku. Vidi ADMIN_LOGIN_401_TRIAGE.md

# Resend (Email)
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="BrziMajstor.ME <noreply@brzimajstor.me>"

# PWA Push Notifications (web-push VAPID keys)
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Javni kontakt (stranica /kontakt). Prazno = default u kodu (brzimajstor.memarketing@gmail.com, +382 68 039 969).
NEXT_PUBLIC_SUPPORT_EMAIL=""
NEXT_PUBLIC_SUPPORT_PHONE=""

# --- Stripe (kupovina kredita majstora) ---
# Test ključevi: https://dashboard.stripe.com/test/apikeys
# Nakon deploya: Developers → Webhooks → Add endpoint → URL: https://VAŠ_DOMEN/api/webhooks/stripe
#   Event: checkout.session.completed → kopiraj "Signing secret" u STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=""
# Javni ključ (Checkout redirect ne zahtijeva na frontendu; ostaje za budući Elements / Payment Request)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# OpenAI (opciono) — predlozi teksta na formi profila majstora (Opis / područje rada)
# Bez ključa dugmad se ne prikazuju. Model default: gpt-4o-mini
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
